<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Klakr.App.ViewModels"
        xmlns:steps="using:Klakr.App.ViewModels.Steps"
        xmlns:conv="using:Klakr.App.Converters"
        x:Class="Klakr.App.Views.ConfigWindow"
        x:CompileBindings="False"
        Icon="/Assets/icon.ico"
        Title="{Binding WindowTitle}" Width="940" Height="640"
        MinWidth="720" MinHeight="480">

    <Window.Resources>
        <!-- Numeric fields use this so an empty/invalid entry is ignored, not an error. -->
        <conv:IntTextConverter x:Key="IntText" />
        <conv:KeyDisplayConverter x:Key="KeyDisplay" />
        <conv:KeepAwakeModeConverter x:Key="KeepAwakeModeDisplay" />
        <!-- Key pickers show friendly names: the digit row as 0-9, not D0-D9. -->
        <DataTemplate x:Key="KeyItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource KeyDisplay}}" />
        </DataTemplate>
        <DataTemplate x:Key="KeepAwakeModeItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource KeepAwakeModeDisplay}}" />
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.step">
            <Setter Property="Background" Value="#22808080" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <Style Selector="Border.branch">
            <Setter Property="BorderBrush" Value="#60808080" />
            <Setter Property="BorderThickness" Value="2,0,0,0" />
            <Setter Property="Margin" Value="10,2,0,2" />
            <Setter Property="Padding" Value="8,2,0,2" />
        </Style>
        <Style Selector="Button.rowbtn">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="MinWidth" Value="34" />
        </Style>
        <Style Selector="TextBlock.kind">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox.num">
            <Setter Property="Width" Value="64" />
        </Style>
    </Window.Styles>

    <Window.DataTemplates>

        <!-- An editable list of steps: the rows, then the add-step bar. Used for the root
             sequence, loop bodies and conditional branches; recursion happens here. -->
        <DataTemplate DataType="steps:StepListViewModel">
            <StackPanel Spacing="4">
                <ItemsControl ItemsSource="{Binding Items}" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Add step:" VerticalAlignment="Center" Foreground="Gray" />
                    <Button Content="Key Tap" Command="{Binding AddStepCommand}" CommandParameter="keyTap" />
                    <Button Content="Delay" Command="{Binding AddStepCommand}" CommandParameter="delay" />
                    <Button Content="Loop" Command="{Binding AddStepCommand}" CommandParameter="loop" />
                    <Button Content="If" Command="{Binding AddStepCommand}" CommandParameter="conditionalBranch" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Key Tap -->
        <DataTemplate DataType="steps:KeyTapStepViewModel">
            <Border Classes="step">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="kind" Text="{Binding Kind}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3">
                            <Button Classes="rowbtn" Content="Up" Command="{Binding MoveUpCommand}" />
                            <Button Classes="rowbtn" Content="Down" Command="{Binding MoveDownCommand}" />
                            <Button Classes="rowbtn" Content="Remove" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Key:" VerticalAlignment="Center" />
                        <ComboBox Width="130" ItemsSource="{Binding AllKeys}" SelectedItem="{Binding Key}"
                                  ItemTemplate="{StaticResource KeyItemTemplate}" />
                        <TextBlock Text="Hold ms:" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBox Classes="num" Text="{Binding HoldMinMs, Converter={StaticResource IntText}}" />
                        <TextBlock Text="to" VerticalAlignment="Center" />
                        <TextBox Classes="num" Text="{Binding HoldMaxMs, Converter={StaticResource IntText}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <CheckBox Content="Custom delay after" IsChecked="{Binding UseCustomDelay}" />
                        <TextBox Classes="num" Text="{Binding DelayMinMs, Converter={StaticResource IntText}}"
                                 IsEnabled="{Binding UseCustomDelay}" />
                        <TextBlock Text="to" VerticalAlignment="Center" />
                        <TextBox Classes="num" Text="{Binding DelayMaxMs, Converter={StaticResource IntText}}"
                                 IsEnabled="{Binding UseCustomDelay}" />
                        <TextBlock Text="ms - otherwise the sequence default" Foreground="Gray"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Delay -->
        <DataTemplate DataType="steps:DelayStepViewModel">
            <Border Classes="step">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="kind" Text="{Binding Kind}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3">
                            <Button Classes="rowbtn" Content="Up" Command="{Binding MoveUpCommand}" />
                            <Button Classes="rowbtn" Content="Down" Command="{Binding MoveDownCommand}" />
                            <Button Classes="rowbtn" Content="Remove" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Wait ms:" VerticalAlignment="Center" />
                        <TextBox Classes="num" Text="{Binding MinMs, Converter={StaticResource IntText}}" />
                        <TextBlock Text="to" VerticalAlignment="Center" />
                        <TextBox Classes="num" Text="{Binding MaxMs, Converter={StaticResource IntText}}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Loop -->
        <DataTemplate DataType="steps:LoopStepViewModel">
            <Border Classes="step">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="kind" Text="{Binding Kind}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3">
                            <Button Classes="rowbtn" Content="Up" Command="{Binding MoveUpCommand}" />
                            <Button Classes="rowbtn" Content="Down" Command="{Binding MoveDownCommand}" />
                            <Button Classes="rowbtn" Content="Remove" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <CheckBox Content="Loop until toggled off" IsChecked="{Binding LoopForever}" />
                        <TextBlock Text="Times:" VerticalAlignment="Center" />
                        <TextBox Classes="num" Text="{Binding Iterations, Converter={StaticResource IntText}}"
                                 IsEnabled="{Binding !LoopForever}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Order:" VerticalAlignment="Center" />
                        <ComboBox Width="150" ItemsSource="{Binding AllSequenceTypes}"
                                  SelectedItem="{Binding Ordering}" />
                        <TextBlock Text="Burst x" VerticalAlignment="Center" />
                        <TextBox Classes="num" Text="{Binding BurstCount, Converter={StaticResource IntText}}"
                                 IsEnabled="{Binding IsBurst}" />
                    </StackPanel>
                    <Border Classes="branch">
                        <ContentControl Content="{Binding Body}" />
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Conditional branch -->
        <DataTemplate DataType="steps:ConditionalBranchStepViewModel">
            <Border Classes="step">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="kind" Text="{Binding Kind}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3">
                            <Button Classes="rowbtn" Content="Up" Command="{Binding MoveUpCommand}" />
                            <Button Classes="rowbtn" Content="Down" Command="{Binding MoveDownCommand}" />
                            <Button Classes="rowbtn" Content="Remove" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="If key held:" VerticalAlignment="Center" />
                        <ComboBox Width="130" ItemsSource="{Binding AllKeys}" SelectedItem="{Binding WatchKey}"
                                  ItemTemplate="{StaticResource KeyItemTemplate}" />
                    </StackPanel>
                    <TextBlock Text="Then:" Foreground="Gray" />
                    <Border Classes="branch">
                        <ContentControl Content="{Binding ThenBranch}" />
                    </Border>
                    <TextBlock Text="Else:" Foreground="Gray" />
                    <Border Classes="branch">
                        <ContentControl Content="{Binding ElseBranch}" />
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.DataTemplates>

    <DockPanel>

      <!-- Update banner - sits above the platform notice so both can show if needed. -->
      <Border DockPanel.Dock="Top" Background="#1F4D2F" Padding="12,8"
              IsVisible="{Binding IsUpdateBannerVisible}">
          <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#B8F0C6"
                         Text="{Binding AvailableUpdateVersion, StringFormat='Update available: v{0}'}" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                  <Button Content="Install and restart"
                          Command="{Binding InstallUpdateCommand}"
                          IsEnabled="{Binding CanInstallUpdate}"
                          ToolTip.Tip="Downloads the update via Velopack and restarts. Disabled in dev builds." />
                  <Button Content="Skip this version" Command="{Binding SkipUpdateCommand}" />
                  <Button Content="Later" Command="{Binding DismissUpdateCommand}"
                          ToolTip.Tip="Hide until the next hourly check." />
              </StackPanel>
          </Grid>
      </Border>

      <!-- Platform warning banner (Wayland / macOS) -->
      <Border DockPanel.Dock="Top" Background="#3D2A00" Padding="12,8"
              IsVisible="{Binding HasPlatformNotice}">
          <TextBlock Text="{Binding PlatformNotice}" Foreground="Orange" TextWrapping="Wrap" />
      </Border>

      <Grid ColumnDefinitions="240,*" Margin="10">

        <!-- Left: profile list -->
        <Border Grid.Column="0" Background="#18808080" CornerRadius="4" Padding="8" Margin="0,0,8,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Profiles" FontSize="16" FontWeight="Bold"
                           Margin="0,0,0,8" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                    <Button Content="New" Command="{Binding NewProfileCommand}" />
                    <Button Content="Duplicate" Command="{Binding DuplicateProfileCommand}" />
                    <Button Content="Delete" Command="{Binding DeleteProfileCommand}" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        ToolTip.Tip="Green = enabled (listens for its hotkey); grey = disabled">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                         Fill="{Binding StatusBrush}" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right: tabs + always-visible action bar -->
        <DockPanel Grid.Column="1">

            <!-- Action bar (always visible across all tabs) -->
            <Border DockPanel.Dock="Bottom" Background="#18808080" CornerRadius="4"
                    Padding="8" Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Button Content="Save profile" Command="{Binding SaveCommand}" />
                        <Button Content="Test (start / stop)" Command="{Binding ToggleEngineCommand}" />
                        <TextBlock Text="Engine:" VerticalAlignment="Center" Foreground="Gray" />
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontWeight="Bold" />
                    </StackPanel>
                    <ToggleButton Grid.Column="1" Content="Keep Awake"
                                  IsChecked="{Binding KeepAwakeActive}"
                                  Margin="0,0,6,0"
                                  ToolTip.Tip="Prevent sleep and/or fool activity-tracking apps like Teams / Slack." />
                    <ToggleButton Grid.Column="2" Content="Display preset"
                                  IsChecked="{Binding DisplayPresetActive}"
                                  IsVisible="{Binding IsNvidiaAvailable}"
                                  ToolTip.Tip="On: apply each monitor's saved preset. Off: restore NVIDIA defaults." />
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl SelectedIndex="0">

                <TabItem Header="Sequence">
                    <DockPanel>
                        <!-- Profile metadata -->
                        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,8,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Profile name:" VerticalAlignment="Center" Width="90" />
                                <TextBox Width="220" Text="{Binding ProfileName}" />
                                <CheckBox Content="Enabled (listens for its hotkey)" VerticalAlignment="Center"
                                          IsChecked="{Binding ProfileEnabled}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Hotkey:" VerticalAlignment="Center" Width="90" />
                                <TextBlock Text="{Binding HotkeyText}" VerticalAlignment="Center" MinWidth="160"
                                           FontWeight="Bold" />
                                <Button Content="Set hotkey" Command="{Binding CaptureHotkeyCommand}" />
                                <TextBlock Text="{Binding HotkeyWarning}" Foreground="Orange"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Sequence type:" VerticalAlignment="Center" Width="90" />
                                <ComboBox Width="150" ItemsSource="{Binding AllSequenceTypes}"
                                          SelectedItem="{Binding Ordering}" />
                                <TextBlock Text="Burst x" VerticalAlignment="Center" />
                                <TextBox Classes="num" Text="{Binding BurstCount, Converter={StaticResource IntText}}"
                                         IsEnabled="{Binding IsBurst}" />
                                <TextBlock Text="Default delay ms:" VerticalAlignment="Center" Margin="12,0,0,0" />
                                <TextBox Classes="num" Text="{Binding DefaultDelayMinMs, Converter={StaticResource IntText}}" />
                                <TextBlock Text="to" VerticalAlignment="Center" />
                                <TextBox Classes="num" Text="{Binding DefaultDelayMaxMs, Converter={StaticResource IntText}}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Sequence editor -->
                        <HeaderedContentControl Header="Sequence (runs on a loop while toggled on)">
                            <ScrollViewer Margin="0,6,0,0">
                                <ContentControl Content="{Binding Sequence}" />
                            </ScrollViewer>
                        </HeaderedContentControl>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Send Key">
                    <ScrollViewer>
                        <StackPanel Spacing="14" Margin="8,12,8,8" MaxWidth="560" HorizontalAlignment="Left">

                            <TextBlock TextWrapping="Wrap" Foreground="Gray"
                                       Text="Synthesize a key your keyboard does not have - useful for binding things like F24 in Discord for push-to-talk. Pick the key, set a countdown so you can Alt-Tab to the target app, then Tap (single press) or Hold (until you Release)." />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Key:" VerticalAlignment="Center" Width="90" />
                                <ComboBox Width="160" ItemsSource="{Binding AllSendKeys}"
                                          SelectedItem="{Binding SelectedSendKey}"
                                          ItemTemplate="{StaticResource KeyItemTemplate}"
                                          IsEnabled="{Binding CanEditSendInputs}" />
                                <TextBlock Text="{Binding SendKeyDescription}" Foreground="Gray"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Countdown:" VerticalAlignment="Center" Width="90" />
                                <TextBox Classes="num" Text="{Binding CountdownSeconds, Converter={StaticResource IntText}}"
                                         IsEnabled="{Binding CanEditSendInputs}" />
                                <TextBlock Text="seconds before send (0 = immediate)"
                                           Foreground="Gray" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Tap once" Command="{Binding TapSendKeyCommand}"
                                        IsEnabled="{Binding CanEditSendInputs}"
                                        ToolTip.Tip="Press and release after the countdown." />
                                <Button Content="{Binding HoldButtonLabel}"
                                        Command="{Binding ToggleHoldSendKeyCommand}"
                                        IsEnabled="{Binding !IsCountdownActive}"
                                        ToolTip.Tip="Hold until clicked again. Released automatically on app quit." />
                                <Button Content="Cancel" Command="{Binding CancelSendCommand}"
                                        IsVisible="{Binding IsCountdownActive}" />
                            </StackPanel>

                            <TextBlock Text="{Binding SendStatus}" Foreground="LightGray"
                                       FontWeight="Bold" />

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Display" IsVisible="{Binding IsNvidiaAvailable}">
                    <ScrollViewer>
                        <StackPanel Spacing="14" Margin="8,12,8,8">

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Monitor:" VerticalAlignment="Center" Width="90" />
                                <ComboBox Width="320" ItemsSource="{Binding MonitorNames}"
                                          SelectedItem="{Binding SelectedMonitor}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="120,*,70"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="10" ColumnSpacing="8">

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Brightness"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding DisplayBrightness}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding DisplayBrightness, StringFormat='{}{0} %'}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Contrast"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding DisplayContrast}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding DisplayContrast, StringFormat='{}{0} %'}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Gamma"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="2" Grid.Column="1" Minimum="0.30" Maximum="2.80"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        Value="{Binding DisplayGamma}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding DisplayGamma, StringFormat='{}{0:0.00}'}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Digital vibrance"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding DisplayVibrance}" />
                                <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding DisplayVibrance, StringFormat='{}{0} %'}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Hue"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="359"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding DisplayHue}" />
                                <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding DisplayHue, StringFormat='{}{0}°'}" />
                            </Grid>

                            <Button Content="Save preset for this monitor"
                                    Command="{Binding SaveDisplayPresetCommand}"
                                    HorizontalAlignment="Left" />

                            <TextBlock Foreground="Gray" TextWrapping="Wrap"
                                       Text="Sliders preview live on the selected monitor. Click Save to capture as the monitor's preset. The 'Display preset' toggle in the bottom bar flips all monitors with saved presets between their preset and NVIDIA defaults." />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                     Fill="{Binding KeepAwakeStateBrush}" />
                            <TextBlock Text="Keep Awake" VerticalAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer>
                        <StackPanel Spacing="14" Margin="8,12,8,8" MaxWidth="640" HorizontalAlignment="Left">

                            <StackPanel Spacing="6">
                                <CheckBox Content="Keep this machine awake"
                                          IsChecked="{Binding KeepAwakeActive}" />
                                <TextBlock Foreground="Gray"
                                           Text="{Binding KeepAwakeStatusText, StringFormat='Status: {0}'}" />
                            </StackPanel>

                            <HeaderedContentControl>
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Method" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="8" Margin="0,6,0,0">
                                    <ComboBox Width="360"
                                              ItemsSource="{Binding AllKeepAwakeModes}"
                                              SelectedItem="{Binding KeepAwakeMode}"
                                              ItemTemplate="{StaticResource KeepAwakeModeItemTemplate}" />
                                    <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                                               Text="Idle-only sends a key only after N seconds of no real input (won't fire while you're typing). Always sends every N seconds. Prevent-sleep uses SetThreadExecutionState with no key events." />
                                </StackPanel>
                            </HeaderedContentControl>

                            <HeaderedContentControl IsVisible="{Binding IsKeySimulationMode}">
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Key" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="8" Margin="0,6,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Send:" Width="90" VerticalAlignment="Center" />
                                        <ComboBox Width="160"
                                                  ItemsSource="{Binding AllSendKeys}"
                                                  SelectedItem="{Binding KeepAwakeKey}"
                                                  ItemTemplate="{StaticResource KeyItemTemplate}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Interval:" Width="90" VerticalAlignment="Center" />
                                        <TextBox Classes="num"
                                                 Text="{Binding KeepAwakeIntervalSeconds, Converter={StaticResource IntText}}" />
                                        <TextBlock Foreground="Gray" VerticalAlignment="Center"
                                                   Text="seconds  (idle threshold or send cadence per mode)" />
                                    </StackPanel>
                                </StackPanel>
                            </HeaderedContentControl>

                            <HeaderedContentControl>
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Active hours" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                    <TextBox Width="360" HorizontalAlignment="Left"
                                             Text="{Binding KeepAwakeTimeRanges}"
                                             PlaceholderText="e.g. 09:00-17:00, 20:00-23:00" />
                                    <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                                               Text="Comma-separated HH:MM-HH:MM ranges. Leave empty for always-active. Ranges may wrap midnight (22:00-06:00)." />
                                </StackPanel>
                            </HeaderedContentControl>

                            <HeaderedContentControl>
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Timed activation" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                    <TextBlock Text="Keep awake for" VerticalAlignment="Center" />
                                    <TextBox Classes="num"
                                             Text="{Binding TimedOnMinutes, Converter={StaticResource IntText}}" />
                                    <TextBlock Text="minutes" VerticalAlignment="Center" />
                                    <Button Content="Start"
                                            Command="{Binding ActivateKeepAwakeTimedCommand}" />
                                </StackPanel>
                            </HeaderedContentControl>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Settings is always the last tab. New feature tabs go BEFORE this one. -->
                <TabItem Header="Settings">
                    <ScrollViewer>
                        <StackPanel Spacing="18" Margin="8,12,8,8" MaxWidth="640" HorizontalAlignment="Left">

                            <!-- Overlay: app-wide, saves live on any change. -->
                            <HeaderedContentControl>
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Overlay" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="8" Margin="0,6,0,0">
                                    <CheckBox Content="Show overlay dot on screen"
                                              IsChecked="{Binding OverlayVisible}" />
                                    <StackPanel Spacing="8" IsEnabled="{Binding OverlayVisible}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Anchor:" VerticalAlignment="Center" Width="90" />
                                            <ComboBox Width="200" ItemsSource="{Binding AllOverlayAnchors}"
                                                      SelectedItem="{Binding OverlayAnchor}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Nudge:" VerticalAlignment="Center" Width="90" />
                                            <TextBlock Text="X" VerticalAlignment="Center" />
                                            <TextBox Classes="num" Text="{Binding OverlayOffsetX, Converter={StaticResource IntText}}" />
                                            <TextBlock Text="Y" VerticalAlignment="Center" />
                                            <TextBox Classes="num" Text="{Binding OverlayOffsetY, Converter={StaticResource IntText}}" />
                                            <TextBlock Text="px  (X+ right, Y+ down)"
                                                       Foreground="Gray" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </HeaderedContentControl>

                            <!-- Startup: writes HKCU Run entry pointing at the current exe with the minimized flag. -->
                            <HeaderedContentControl IsVisible="{Binding IsStartWithWindowsSupported}">
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Startup" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="6" Margin="0,6,0,0">
                                    <CheckBox Content="Start Klakr with Windows"
                                              IsChecked="{Binding StartWithWindows}"
                                              ToolTip.Tip="Adds an HKCU Run entry. Path is refreshed on each launch so it survives Velopack updates." />
                                    <TextBlock Text="Launches minimized to the system tray; click the tray icon to open the config window."
                                               Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
                                </StackPanel>
                            </HeaderedContentControl>

                            <!-- About: static info about the running build. -->
                            <HeaderedContentControl>
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="About" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="4" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding DiagnosticsKlakrVersion}" FontWeight="Bold" />
                                    <TextBlock Text="{Binding DiagnosticsDotNet}" Foreground="Gray" />
                                    <TextBlock Text="{Binding DiagnosticsOs}" Foreground="Gray" />
                                    <TextBlock Text="{Binding DiagnosticsSharpHook}" Foreground="Gray" />
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                                        <TextBlock Text="Source:" Foreground="Gray" VerticalAlignment="Center" />
                                        <Button Content="{Binding DiagnosticsRepoUrl}"
                                                Command="{Binding OpenRepoUrlCommand}"
                                                Padding="4,0" Background="Transparent" BorderThickness="0"
                                                Foreground="LightSkyBlue"
                                                ToolTip.Tip="Open on GitHub" />
                                    </StackPanel>
                                </StackPanel>
                            </HeaderedContentControl>

                            <!-- Diagnostics: live info + shortcuts for the profile / settings folders. -->
                            <HeaderedContentControl>
                                <HeaderedContentControl.Header>
                                    <TextBlock Text="Diagnostics" FontWeight="Bold" />
                                </HeaderedContentControl.Header>
                                <StackPanel Spacing="10" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding DiagnosticsNvidia}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding DiagnosticsUpdateStatus}"
                                                   VerticalAlignment="Center" />
                                        <Button Content="Check now"
                                                Command="{Binding CheckForUpdatesNowCommand}"
                                                IsEnabled="{Binding !IsCheckingForUpdates}"
                                                IsVisible="{Binding !IsUpdateBannerVisible}"
                                                Padding="8,2" />
                                        <Button Content="Install and restart"
                                                Command="{Binding InstallUpdateCommand}"
                                                IsEnabled="{Binding CanInstallUpdate}"
                                                IsVisible="{Binding IsUpdateBannerVisible}"
                                                Padding="8,2"
                                                Background="#1F4D2F" Foreground="#B8F0C6" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open profiles folder"
                                                Command="{Binding OpenProfilesFolderCommand}" />
                                        <TextBlock Text="{Binding DiagnosticsProfilesFolder}"
                                                   Foreground="Gray" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="380" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Show settings file"
                                                Command="{Binding OpenSettingsLocationCommand}" />
                                        <TextBlock Text="{Binding DiagnosticsSettingsFile}"
                                                   Foreground="Gray" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="380" />
                                    </StackPanel>

                                    <Button Content="Copy diagnostics to clipboard"
                                            Click="OnCopyDiagnosticsClick"
                                            HorizontalAlignment="Left" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding CopyDiagnosticsStatus}"
                                               IsVisible="{Binding HasCopyDiagnosticsStatus}"
                                               Foreground="LightGreen" FontSize="11" />
                                </StackPanel>
                            </HeaderedContentControl>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

        </DockPanel>
      </Grid>
    </DockPanel>
</Window>
